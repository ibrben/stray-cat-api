{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=${DB_HOST};Port=${DB_PORT};Database=${DB_NAME};Username=${DB_USERNAME};Password=${DB_PASSWORD}"
  },
  "Jwt": {
    "Key": "${JWT_KEY}",
    "Issuer": "${JWT_ISSUER}",
    "Audience": "${JWT_AUDIENCE}"
  },
  "Authentication": {
    "Google": {
      "ClientId": "${GOOGLE_CLIENT_ID}",
      "ClientSecret": "${GOOGLE_CLIENT_SECRET}",
      "AllowedDomains": "${GOOGLE_ALLOWED_DOMAINS}"
    }
  },
  "Frontend": {
    "Url": "${FRONTEND_URL}"
  },
  "CloudflareR2": {
    "AccessKeyId": "${CLOUDFLARE_ACCESS_KEY_ID}",
    "SecretAccessKey": "${CLOUDFLARE_SECRET_ACCESS_KEY}",
    "ServiceUrl": "${CLOUDFLARE_SERVICE_URL}",
    "BucketName": "${CLOUDFLARE_BUCKET_NAME}",
    "BaseUrl": "${CLOUDFLARE_BASE_URL}",
    "CdnUrl": "${CLOUDFLARE_CDN_URL}"
  }
}
