# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=straycat
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT Configuration
JWT_KEY=ThisIsASecretKeyForJWTTokenGeneration1234567890
JWT_ISSUER=StrayCatAPI
JWT_AUDIENCE=StrayCatClient

# Google Authentication
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_ALLOWED_DOMAINS=gmail.com,outlook.com,yourdomain.com

# Frontend Configuration
FRONTEND_URL=http://localhost:5173

# Cloudflare R2 Configuration
CLOUDFLARE_ACCESS_KEY_ID=your-access-key-id
CLOUDFLARE_SECRET_ACCESS_KEY=your-secret-access-key
CLOUDFLARE_SERVICE_URL=https://your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_BUCKET_NAME=stray-cat-images
CLOUDFLARE_BASE_URL=https://your-bucket.your-account-id.r2.cloudflarestorage.com
CLOUDFLARE_CDN_URL=https://your-cdn-domain.com

# ASP.NET Core Configuration
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:80
